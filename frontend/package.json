{
  "name": "frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxi dev",
    "build": "nuxi build",
    "generate": "nuxi generate",
    "build:django": "node update-django-template.js",
    "preview": "nuxi preview",
    "postinstall": "nuxi prepare && npx playwright install chromium",
    "optimize-images": "node scripts/optimize-images.js",
    "test": "NODE_OPTIONS='--no-deprecation' jest --config jest.config.cjs",
    "test:watch": "NODE_OPTIONS='--no-deprecation' jest --config jest.config.cjs --watch",
    "test:coverage": "NODE_OPTIONS='--no-deprecation' jest --config jest.config.cjs --coverage && node scripts/coverage-summary.cjs",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:coverage": "e2e:clean && playwright test",
    "e2e:clean": "rm -rf e2e-results"
  },
  "dependencies": {
    "@headlessui/vue": "^1.7.22",
    "@heroicons/vue": "^2.1.3",
    "@splinetool/runtime": "^1.9.37",
    "axios": "^1.7.2",
    "dompurify": "^3.3.2",
    "gsap": "^3.13.0",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.0",
    "lottie-web": "^5.12.2",
    "marked": "^17.0.4",
    "pinia": "^2.1.7",
    "plyr": "^3.8.4",
    "sweetalert2": "^11.11.1",
    "swiper": "^12.0.3",
    "video.js": "^8.12.0",
    "vue3-emoji-picker": "^1.1.8",
    "vue3-lottie": "^3.3.1",
    "vue3-marquee": "^4.2.0",
    "vue3-spline": "^1.0.0",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@nuxtjs/i18n": "^9.1.0",
    "@nuxtjs/tailwindcss": "^6.12.0",
    "@pinia/nuxt": "^0.5.5",
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@vue/test-utils": "^2.4.6",
    "@vue/vue3-jest": "^29.2.6",
    "babel-jest": "^29.7.0",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-transform-stub": "^2.0.0",
    "nuxt": "^3.14.0",
    "vue": "^3.4.21",
    "vue-router": "^4.3.0"
  }
}
