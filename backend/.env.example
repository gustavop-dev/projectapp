# ===========================================
# ENVIRONMENT CONFIGURATION — projectapp
# ===========================================

# Django Core
DJANGO_ENV=development
DJANGO_SECRET_KEY=replace-with-strong-secret-min-50-chars
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_LOG_LEVEL=INFO

# ===========================================
# DATABASE (Production: MySQL, Dev: SQLite default)
# ===========================================
# DB_NAME=your_db_name
# DB_USER=replace
# DB_PASSWORD=replace
# DB_HOST=localhost
# DB_PORT=3306

# ===========================================
# EMAIL (GoDaddy SMTP)
# ===========================================
EMAIL_HOST=smtpout.secureserver.net
EMAIL_PORT=465
EMAIL_USE_SSL=true
EMAIL_HOST_USER=replace
EMAIL_HOST_PASSWORD=replace
DEFAULT_FROM_EMAIL=team@projectapp.co
NOTIFICATION_EMAIL=replace

# ===========================================
# WHATSAPP (CallMeBot)
# ===========================================
WHATSAPP_PHONE=replace
CALLMEBOT_API_KEY=replace

# ===========================================
# CORS / CSRF
# ===========================================
DJANGO_CORS_ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# ===========================================
# TASK QUEUE (Huey + Redis)
# ===========================================
REDIS_URL=redis://localhost:6379/5

# ===========================================
# BACKUPS
# ===========================================
BACKUP_STORAGE_PATH=/var/backups/projectapp

# ===========================================
# WOMPI (Payment Gateway)
# ===========================================
WOMPI_PUBLIC_KEY=pub_test_xxxxx
WOMPI_PRIVATE_KEY=prv_test_xxxxx
WOMPI_EVENTS_SECRET=test_events_xxxxx
WOMPI_INTEGRITY_SECRET=test_integrity_xxxxx
WOMPI_API_URL=https://sandbox.wompi.co/v1

# ===========================================
# MONITORING (Silk - conditional)
# ===========================================
ENABLE_SILK=false
SLOW_QUERY_THRESHOLD_MS=500
N_PLUS_ONE_THRESHOLD=10
