# ===========================================
# .env_development — host-only network dev profile
# ===========================================
# Loaded by backend/projectapp/settings_dev.py when present.
# Production (settings_prod.py) ignores this file entirely.
# Gitignored (matches `*.env`).
#
# Target: VirtualBox host-only adapter at 192.168.56.10
#   - Backend (Django runserver) -> http://192.168.56.10:8000
#   - Frontend (Nuxt dev)        -> http://192.168.56.10:3000

# ---- Hosts the Django dev server will answer to
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,192.168.56.10

# ---- Origins trusted for CSRF (must match the browser's Origin header)
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://192.168.56.10:3000,http://localhost:8000,http://127.0.0.1:8000,http://192.168.56.10:8000

# ---- CORS origins allowed for XHR/fetch from the SPA
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://192.168.56.10:3000

# ---- Frontend base URL used when Django builds public links (emails, etc.)
FRONTEND_BASE_URL=http://192.168.56.10:3000
